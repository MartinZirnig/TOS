{
    "configurations": [
        {
            "name": "Kernel-i386",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src/shared",
                "${workspaceFolder}/src/shared/HW_IO",
                "${workspaceFolder}/src/shared/String",
                "${workspaceFolder}/src/shared/Memory", 
                "${workspaceFolder}/src/shared/VGA",
                "${workspaceFolder}/src/shared/Paging",
                "${workspaceFolder}/src/shared/Context",
                "${workspaceFolder}/src/shared/Math"
            ],
            "defines": [
                "__freestanding__"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-x86",
            "compilerArgs": [
                "-m32",
                "-ffreestanding",
                "-nostdinc"
            ]
        }
    ],
    "version": 4
}